# Primary provider key (Serper)
SERPER_API_KEY=

# Secondary provider key options (set one or both)
TAVILY_API_KEY=
EXA_API_KEY=

# Kite proof write configuration
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
KITE_EXPLORER_URL=https://testnet.kitescan.ai
KITE_PRIVATE_KEY=
KITE_PROOF_RECIPIENT=

GOOGLE_API_KEY=

# Database configuration (PostgreSQL)
DATABASE_ENABLED=false
DATABASE_URL=postgresql+psycopg://kiteai:kiteai_dev_password@localhost:5432/kiteai
# From backend/: alembic upgrade head
# After successful migration, set DATABASE_ENABLED=true and restart backend

# x402 real payment flow (HTTP 402 + facilitator settlement)
X402_ENABLED=false
X402_FACILITATOR_URL=https://facilitator.pieverse.io/v2
X402_NETWORK=eip155:2368
X402_ASSET=0x1b7425d288ea676FCBc65c29711fccF0B6D5c293
X402_PAY_TO=
X402_MERCHANT_NAME=AgentIntel
X402_MAX_TIMEOUT_SECONDS=300
X402_TOKEN_DECIMALS=18
# Optional EIP-712 domain metadata forwarded in accepts[].extra for EVM exact scheme.
# Set these when your payment token requires explicit domain reconstruction by facilitator.
X402_EIP712_DOMAIN_NAME=Kite X402 USD
X402_EIP712_DOMAIN_VERSION=1
# x402 runbook
# 1) Set X402_ENABLED=true and X402_PAY_TO to your Kite wallet address
# 2) Client requests POST /sessions or POST /tasks without payment
# 3) Backend responds 402 with PAYMENT-REQUIRED header and accepts[] body
# 4) x402-compatible client retries with PAYMENT-SIGNATURE or X-PAYMENT
# 5) Backend extracts authorization/signature/network from token and calls facilitator /v2/settle
# 6) Backend returns the paid response when settlement succeeds
# Helpful local checks:
#   python scripts/deploy_x402_test_token.py
#   python scripts/smoke_x402_flow.py --backend-url http://127.0.0.1:8000
#   python scripts/x402_challenge_export.py --backend-url http://127.0.0.1:8000 --output .tmp/x402-challenge.json
#   python scripts/x402_manual_buyer.py --backend-url http://127.0.0.1:8000 --budget 5

# Kite Service Payment API (optional callback after successful settlement)
KITE_SERVICE_PAYMENT_API_ENABLED=false
KITE_SERVICE_PAYMENT_API_URL=
KITE_SERVICE_PAYMENT_API_KEY=
KITE_SERVICE_PAYMENT_API_TIMEOUT_SECONDS=15

# Kite Pass — on-chain ERC-721/1155 ownership verification
KITE_PASS_ENABLED=false
KITE_PASS_CACHE_MINUTES=30
# Comma-separated lowercase wallet addresses that always receive a pass (dev override)
KITE_PASS_ALLOWLIST=
# On-chain verification (leave blank to use allowlist-only mode)
# KITE_PASS_RPC_URL=https://mainnet.infura.io/v3/<YOUR_KEY>
# KITE_PASS_CONTRACT_ADDRESS=0x...
# KITE_PASS_TOKEN_STANDARD=erc721   # erc721 | erc1155
# KITE_PASS_TOKEN_ID=0              # token ID for ERC-1155 balanceOf queries

# Real Kite Agent Passport API mode (optional)
# When enabled, /passport/sessions and /passport/delegations use Kite API instead of local mapped views.
KITE_PASSPORT_REMOTE_ENABLED=false
KITE_PASSPORT_API_URL=
KITE_PASSPORT_API_KEY=
KITE_PASSPORT_TIMEOUT_SECONDS=15
# If true, local mapped endpoints remain available when Kite Passport API is unreachable.
KITE_PASSPORT_LOCAL_FALLBACK=true

# Pass-aware paywall policy (applied when KITE_PASS_ENABLED=true and X402_ENABLED=true)
#   bypass   – pass holders skip payment entirely (default)
#   discount – pass holders pay reduced amount (see KITE_PASS_DISCOUNT_PCT)
# KITE_PASS_PAYWALL_POLICY=bypass
# KITE_PASS_DISCOUNT_PCT=100        # 100 = free, 50 = half price, 0 = no discount

# Security hardening knobs (optional)
CHALLENGE_EXPIRY_MINUTES=10
CHALLENGE_PRUNE_GRACE_MINUTES=30
CHALLENGE_RATE_WINDOW_SECONDS=60
SESSION_CHALLENGE_RATE_LIMIT=6
TASK_CHALLENGE_RATE_LIMIT=10
SESSION_CHALLENGE_RATE_LIMIT_IP=20
TASK_CHALLENGE_RATE_LIMIT_IP=30
CHALLENGE_PRUNE_INTERVAL_SECONDS=60